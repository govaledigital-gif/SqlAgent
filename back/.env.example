# ============================================
# SQL Architect - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# IMPORTANT: Never commit .env to version control

# ============ DATABASE ============
# Required: MySQL database URL
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/database_name

# Optional: Database connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============ REDIS ============
# Optional: Redis cache configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_ENABLED=true

# ============ API ============
# Server configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Environment: development, staging, production
ENVIRONMENT=development

# ============ SECURITY ============
# Required: Strong JWT secret (at least 32 characters for production)
JWT_SECRET=your-super-secret-key-change-this-in-production-min-32-chars

JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# Password validation
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# CORS - Comma-separated list of allowed origins
# For production: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000

CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST
CORS_ALLOW_HEADERS=Content-Type,Authorization
CORS_MAX_AGE=600

# HTTPS/TLS
FORCE_HTTPS=false
SSL_CERTFILE=
SSL_KEYFILE=

# ============ AI/LLM ============
# Required: Google Generative AI API key
GOOGLE_API_KEY=your-google-api-key-here

LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# ============ LOGGING ============
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=json

# Optional: Sentry error tracking DSN
SENTRY_DSN=

# ============ FEATURES ============
# Schema cache TTL in seconds (default: 1 hour)
SCHEMA_CACHE_TTL=3600

# Query history retention in days
QUERY_HISTORY_RETENTION_DAYS=90

# Maximum query length in characters
MAX_QUERY_LENGTH=5000

# Maximum prompt length in characters
MAX_PROMPT_LENGTH=2000

# ============ PRODUCTION CHECKLIST ============
# Before deploying to production, ensure:
# 1. DATABASE_URL points to secure managed database
# 2. JWT_SECRET is 32+ random characters (use: openssl rand -hex 32)
# 3. GOOGLE_API_KEY is valid and has appropriate permissions
# 4. ENVIRONMENT=production
# 5. FORCE_HTTPS=true
# 6. API_RELOAD=false
# 7. CORS_ORIGINS explicitly set to your domain(s)
# 8. LOG_LEVEL=WARNING
# 9. Use environment variable management system (AWS Secrets Manager, Azure Vault, etc.)
# 10. Never commit .env file to version control
